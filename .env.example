# ============================================================
# LEMAN NEGÓCIOS IMOBILIÁRIOS — Variáveis de Ambiente
# Copie este arquivo para .env (desenvolvimento) ou configure
# diretamente no Coolify / servidor de produção.
# ============================================================

# ─── OBRIGATÓRIAS ────────────────────────────────────────────
# Banco de dados (Supabase Transaction Pooler, porta 6543)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:6543/postgres?pgbouncer=true

# Segredo JWT (mínimo 32 caracteres, use: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_min_32_chars

# ─── SERVIDOR ────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ─── SUPABASE STORAGE ────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_BUCKET=LEMANIMAGENS

# ─── IA — GOOGLE GEMINI ──────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
# Usado pelo AI Agent (WhatsApp inbox, análise de leads)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── WHATSAPP / N8N ──────────────────────────────────────────
# Token de autenticação para o webhook N8N → Leman
N8N_WEBHOOK_TOKEN=your_n8n_webhook_token_here

# URL do webhook N8N para envio de leads
N8N_LEAD_WEBHOOK_URL=https://your-n8n-instance.com/webhook/leads

# URL do webhook N8N para chat (exposta ao frontend via VITE_)
VITE_N8N_CHAT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chat

# ─── OAUTH (OPCIONAL) ────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=leman-negocios-imobiliarios

# ─── STORAGE S3-COMPATÍVEL (OPCIONAL — alternativa ao Supabase) ──
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ─── GOOGLE MAPS (OPCIONAL) ──────────────────────────────────
# Exibido no frontend para mapas de imóveis
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── SEGURANÇA (OPCIONAL) ────────────────────────────────────
# Token para ingestão de erros do cliente (ErrorBoundary)
CLIENT_ERROR_TOKEN=

# ─── FORGE / MANUS RUNTIME (GERADO AUTOMATICAMENTE) ─────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
